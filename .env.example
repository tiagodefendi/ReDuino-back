# URL de conexão do banco PostgreSQL (Neon ou outro)
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Porta serial do gateway Arduino
# Windows: COM3, COM4...
# Linux/Mac: /dev/ttyUSB0, /dev/ttyACM0...
SERIAL_PORT=/dev/ttyUSB0

# Porta HTTP do servidor
PORT=3001

# URL do frontend (para CORS)
FRONTEND_URL=http://localhost:3000

# Identificador do nó sensor de ultrassom (origem do Arduino)
# Deve bater com a variável `origem` no sketch do sensor
SENSOR_NODE_ID=47
